{
  "name": "mesh-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "bunx oxlint@latest . --config .oxlintrc.json",
    "lint:fix": "bunx oxlint@latest . --config .oxlintrc.json --fix",
    "format": "bunx oxfmt@latest .",
    "format:check": "bunx oxfmt@latest . --check",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
