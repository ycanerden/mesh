'use client'

import { useState } from 'react'
import { CouncilVerdict } from '@/components/CouncilVerdict'
import { DivergenceMap } from '@/components/DivergenceMap'
import { ModelCard } from '@/components/ModelCard'
import type { CouncilResponse } from '@/lib/types'

type Phase = 'idle' | 'consulting' | 'synthesizing' | 'done' | 'error'

export default function Home() {
  const [prompt, setPrompt] = useState('')
  const [phase, setPhase] = useState<Phase>('idle')
  const [result, setResult] = useState<CouncilResponse | null>(null)
  const [errorMsg, setErrorMsg] = useState('')

  const canSubmit = prompt.trim().length > 0 && prompt.length <= 4000 && phase === 'idle'

  async function handleSubmit() {
    if (!canSubmit) return
    setPhase('consulting')
    setResult(null)
    setErrorMsg('')

    // Switch to "synthesizing" label after ~20s to indicate second phase
    const synthesizingTimer = setTimeout(() => setPhase('synthesizing'), 20_000)

    try {
      const res = await fetch('/api/council', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prompt: prompt.trim() }),
      })
      clearTimeout(synthesizingTimer)

      if (!res.ok) {
        const body = await res.json()
        throw new Error(body.error ?? 'Request failed')
      }

      const data: CouncilResponse = await res.json()
      setResult(data)
      setPhase('done')
    } catch (err) {
      clearTimeout(synthesizingTimer)
      setErrorMsg(err instanceof Error ? err.message : 'Something went wrong')
      setPhase('error')
    }
  }

  const isLoading = phase === 'consulting' || phase === 'synthesizing'
  const isSynthesisUnavailable =
    result?.verdict?.toLowerCase().includes('unavailable') ||
    result?.verdict?.toLowerCase().includes('no models responded') ||
    false

  return (
    <main className="min-h-screen bg-gray-50">
      <div className="max-w-4xl mx-auto px-4 py-12">

        {/* Header */}
        <div className="mb-10">
          <h1 className="text-2xl font-bold tracking-tight text-gray-900">
            Council
            <span className="ml-3 text-sm font-normal text-gray-400">multi-model research</span>
          </h1>
          <p className="mt-1 text-sm text-gray-500">
            Ask a hard question. Get 6 AI perspectives + a synthesized verdict.
          </p>
        </div>

        {/* Prompt input */}
        <div className="bg-white border border-gray-200 rounded-xl p-5 shadow-sm mb-8">
          <label className="block text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">
            Your question
          </label>
          <textarea
            className="w-full border border-gray-200 rounded-lg p-3 text-sm text-gray-800 bg-gray-50 resize-none focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent"
            rows={3}
            placeholder="Should we raise a seed round now or wait until we have more traction?"
            value={prompt}
            onChange={e => setPrompt(e.target.value)}
            disabled={isLoading}
          />
          <div className="flex items-center justify-between mt-3">
            <span className={`text-xs ${prompt.length > 3800 ? 'text-red-400' : 'text-gray-300'}`}>
              {prompt.length}/4000
            </span>
            <button
              onClick={handleSubmit}
              disabled={!canSubmit}
              className="bg-gray-900 text-white text-sm font-semibold px-5 py-2 rounded-lg disabled:opacity-40 disabled:cursor-not-allowed hover:bg-gray-700 transition-colors"
            >
              Ask the Council →
            </button>
          </div>
        </div>

        {/* Loading */}
        {isLoading && (
          <div className="text-center py-16">
            <div className="inline-block w-8 h-8 border-2 border-gray-900 border-t-transparent rounded-full animate-spin mb-4" />
            <p className="text-sm text-gray-500">
              {phase === 'consulting' ? 'Consulting models...' : 'Synthesizing the council verdict...'}
            </p>
          </div>
        )}

        {/* Error */}
        {phase === 'error' && (
          <div className="bg-red-50 border border-red-200 rounded-xl p-5 text-sm text-red-700">
            {errorMsg}
            <button
              onClick={() => setPhase('idle')}
              className="ml-3 underline text-red-500 hover:text-red-700"
            >
              Try again
            </button>
          </div>
        )}

        {/* Results */}
        {phase === 'done' && result && (
          <div className="space-y-6">
            <CouncilVerdict verdict={result.verdict} isSynthesisUnavailable={isSynthesisUnavailable} />

            {result.divergence.length > 0 && (
              <DivergenceMap divergence={result.divergence} modelResponses={result.modelResponses} />
            )}

            <div>
              <p className="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
                Individual Responses
              </p>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                {result.modelResponses.map(r => (
                  <ModelCard key={r.model} result={r} divergence={result.divergence} />
                ))}
              </div>
            </div>

            <button
              onClick={() => { setPhase('idle'); setResult(null) }}
              className="text-xs text-gray-400 hover:text-gray-600 underline"
            >
              ← Ask another question
            </button>
          </div>
        )}
      </div>
    </main>
  )
}
