import { describe, it, expect, vi, beforeEach } from 'vitest'

// Mock the heavy dependencies so tests run without real API keys
vi.mock('@/lib/models', () => ({
  fanOut: vi.fn(),
}))
vi.mock('@/lib/judge', () => ({
  callJudge: vi.fn(),
}))

import { POST } from '../route'
import { fanOut } from '@/lib/models'
import { callJudge } from '@/lib/judge'
import { NextRequest } from 'next/server'

function makeRequest(body: unknown): NextRequest {
  return new NextRequest('http://localhost/api/council', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  })
}

beforeEach(() => {
  vi.clearAllMocks()
})

describe('POST /api/council', () => {
  it('returns 400 for empty prompt', async () => {
    const res = await POST(makeRequest({ prompt: '' }))
    expect(res.status).toBe(400)
    const body = await res.json()
    expect(body.error).toMatch(/required/i)
  })

  it('returns 400 for prompt over 4000 chars', async () => {
    const res = await POST(makeRequest({ prompt: 'a'.repeat(4001) }))
    expect(res.status).toBe(400)
    const body = await res.json()
    expect(body.error).toMatch(/4000/i)
  })

  it('returns 400 for missing prompt field', async () => {
    const res = await POST(makeRequest({}))
    expect(res.status).toBe(400)
  })

  it('returns council response on success', async () => {
    const mockResponses = [
      { model: 'gpt-4o', displayName: 'GPT-4o', abbreviation: 'G', response: 'Response A', available: true },
    ]
    const mockJudge = { verdict: 'The verdict.', divergence: [] }
    vi.mocked(fanOut).mockResolvedValue(mockResponses)
    vi.mocked(callJudge).mockResolvedValue(mockJudge)

    const res = await POST(makeRequest({ prompt: 'Should we expand to EU?' }))
    expect(res.status).toBe(200)
    const body = await res.json()
    expect(body.verdict).toBe('The verdict.')
    expect(body.modelResponses).toHaveLength(1)
  })

  it('returns synthesis unavailable when all models fail', async () => {
    const allFailed = [
      { model: 'gpt-4o', displayName: 'GPT-4o', abbreviation: 'G', response: '', available: false },
      { model: 'claude-sonnet-4-5-20251001', displayName: 'Claude Sonnet', abbreviation: 'C', response: '', available: false },
    ]
    vi.mocked(fanOut).mockResolvedValue(allFailed)
    vi.mocked(callJudge).mockResolvedValue({
      verdict: 'No models responded — check your API keys and try again.',
      divergence: [],
    })

    const res = await POST(makeRequest({ prompt: 'Test question' }))
    expect(res.status).toBe(200)
    const body = await res.json()
    expect(body.verdict).toMatch(/No models responded/i)
  })
})
