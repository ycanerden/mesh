// Groq — free tier, OpenAI-compatible, fast inference
async function callGroq(prompt: string): Promise<ModelResult> {
  const key = process.env.GROQ_API_KEY
  const modelId = 'llama-3.3-70b-versatile'
  if (!key) return unavailable(modelId)
  try {
    const text = await callOpenAICompatible(
      'https://api.groq.com/openai',
      key,
      modelId,
      prompt,
      AbortSignal.timeout(TIMEOUT_MS),
    )
    return { model: modelId, displayName: 'Llama 3.3 (Groq)', abbreviation: 'L', response: truncate(text), available: true }
  } catch {
    return unavailable(modelId)
  }
}

export async function fanOut(prompt: string): Promise<ModelResult[]> {
  const results = await Promise.allSettled([
    callClaude(prompt),   // Haiku — cheap
    callGemini(prompt),   // Flash — free tier
    callDeepSeek(prompt), // Very cheap
    callGroq(prompt),     // Llama 3.3 70B — free
  ])
  return results.map(r => (r.status === 'fulfilled' ? r.value : unavailable((r as PromiseRejectedResult).reason)))
}
