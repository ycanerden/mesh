<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero-label">Technical Hackathons</div>
    <h1>One day. One team.<br><em>One working product.</em></h1>
    <p class="hero-sub">Full-day deep builds for developers and technical founders. Real infrastructure. Real stakes. Ship or learn — either way you win.</p>
    <div class="hero-meta">
      <div class="hero-meta-item">
