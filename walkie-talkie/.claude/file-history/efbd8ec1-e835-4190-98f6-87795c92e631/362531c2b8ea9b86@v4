<style>
:root {
  --bg: #fafaf8;
  --text: #1c1b1a;
  --cream: #f0ede6;
  --gray: #6b6864;
  --gray-light: #8a8780;
  --accent: #3d5afc;
  --accent-glow: #2d4ae8;
  --coral: #e85a35;
  --teal: #16b889;
  --purple: #7c4fcc;
  --font-display: 'Space Mono', monospace;
  --font-body: 'Outfit', sans-serif;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
section { padding: 120px 0; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 0;
  background: rgba(250,250,248,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(28,27,26,0.08);
}
nav .container { display: flex; align-items: center; justify-content: space-between; }
.logo { font-family: var(--font-display); font-size: 18px; font-weight: 700; letter-spacing: -0.5px; }

.nav-links { display: flex; gap: 32px; align-items: center; list-style: none; }
.nav-links a { font-size: 14px; font-weight: 400; color: var(--gray); transition: color 0.2s; }
.nav-links a:hover { color: var(--text); }
.nav-links a.active { color: var(--accent); font-weight: 500; }
.nav-cta {
  background: var(--accent); color: #ffffff !important;
  padding: 10px 24px; border-radius: 6px;
  font-weight: 600; font-size: 14px; transition: background 0.2s;
}
.nav-cta:hover { background: var(--accent-glow) !important; }

/* HERO */
.hero {
  min-height: 80vh; display: flex; align-items: center;
  padding-top: 100px; position: relative;
}
.hero::before {
  content: ''; position: absolute; top: -100px; right: -200px;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(61,90,252,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-display); font-size: 11px;
  letter-spacing: 1.5px; text-transform: uppercase;
  background: rgba(61,90,252,0.1); color: var(--accent);
  padding: 6px 14px; border-radius: 4px; margin-bottom: 24px;
}
.hero-label {
  font-family: var(--font-display); font-size: 13px;
  color: var(--accent); letter-spacing: 2px; text-transform: uppercase;
  margin-bottom: 24px; display: flex; align-items: center; gap: 12px;
}
.hero-label::before { content: ''; width: 40px; height: 1px; background: var(--accent); }
.hero h1 {
  font-size: clamp(48px, 7vw, 76px); font-weight: 700;
  line-height: 1.05; letter-spacing: -2px; margin-bottom: 28px;
}
.hero h1 em { font-style: normal; color: var(--accent); }
.hero-sub {
  font-size: 20px; color: var(--gray); max-width: 560px;
  line-height: 1.6; margin-bottom: 48px; font-weight: 300;
}
.hero-meta {
  display: flex; gap: 32px; flex-wrap: wrap; margin-bottom: 48px;
}
.hero-meta-item {
  display: flex; flex-direction: column; gap: 4px;
}
.hero-meta-label { font-size: 12px; color: var(--gray); text-transform: uppercase; letter-spacing: 1px; }
.hero-meta-value { font-family: var(--font-display); font-size: 16px; font-weight: 700; }
.hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; }
.btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--accent); color: #ffffff;
  padding: 16px 32px; border-radius: 8px;
  font-weight: 600; font-size: 16px;
  transition: all 0.2s; border: none; cursor: pointer;
}
.btn-primary:hover { background: var(--accent-glow); transform: translateY(-1px); }
.btn-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  background: transparent; color: var(--text);
  padding: 16px 32px; border-radius: 8px;
  font-weight: 500; font-size: 16px;
  border: 1px solid rgba(28,27,26,0.18); transition: all 0.2s; cursor: pointer;
}
.btn-secondary:hover { border-color: rgba(28,27,26,0.35); background: rgba(28,27,26,0.04); }

/* FORMAT SECTION */
.format-section { background: var(--cream); }
.section-label {
  font-family: var(--font-display); font-size: 13px;
  color: var(--accent); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
}
.section-title {
  font-size: clamp(36px, 5vw, 56px); font-weight: 700;
  letter-spacing: -1.5px; margin-bottom: 16px; line-height: 1.1;
}
.section-sub { font-size: 18px; color: var(--gray); max-width: 600px; margin-bottom: 64px; font-weight: 300; }

.timeline {
  display: flex; flex-direction: column; gap: 0;
  max-width: 720px; margin-top: 64px;
}
.timeline-item {
  display: flex; gap: 32px; position: relative; padding-bottom: 40px;
}
.timeline-item:last-child { padding-bottom: 0; }
.timeline-time {
  font-family: var(--font-display); font-size: 14px;
  color: var(--accent); min-width: 80px; padding-top: 2px;
}
.timeline-dot {
  display: flex; flex-direction: column; align-items: center; gap: 0;
}
.timeline-dot-circle {
  width: 12px; height: 12px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0; margin-top: 6px;
}
.timeline-dot-line {
  width: 1px; background: rgba(28,27,26,0.12);
  flex: 1; margin-top: 4px;
}
.timeline-item:last-child .timeline-dot-line { display: none; }
.timeline-content { flex: 1; }
.timeline-content h3 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
.timeline-content p { font-size: 15px; color: var(--gray); line-height: 1.6; }

/* WHO SECTION */
.who-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px; margin-top: 64px;
}
.who-card {
  background: #ffffff; border: 1px solid rgba(28,27,26,0.08);
  border-radius: 16px; padding: 32px;
  box-shadow: 0 1px 4px rgba(28,27,26,0.04);
}
.who-card-icon {
  font-size: 28px; margin-bottom: 16px;
}
.who-card h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
.who-card p { font-size: 14px; color: var(--gray); line-height: 1.6; }

/* SPONSORS SECTION */
.sponsors-section { background: var(--cream); }
.sponsor-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 32px; margin-top: 64px;
}
.sponsor-card {
  background: #ffffff; border: 1px solid rgba(28,27,26,0.08);
  border-radius: 16px; padding: 36px 32px;
  box-shadow: 0 1px 4px rgba(28,27,26,0.04);
}
.sponsor-label {
  font-family: var(--font-display); font-size: 11px;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--accent); margin-bottom: 16px;
}
.sponsor-card h3 { font-size: 20px; font-weight: 600; margin-bottom: 12px; }
.sponsor-card p { font-size: 15px; color: var(--gray); line-height: 1.7; }
.sponsor-card ul { list-style: none; margin-top: 20px; display: flex; flex-direction: column; gap: 8px; }
.sponsor-card ul li {
  font-size: 14px; color: var(--gray); display: flex; align-items: center; gap: 10px;
}
.sponsor-card ul li::before { content: '→'; color: var(--accent); font-size: 12px; }

/* OUTPUT SECTION */
.output-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 48px; margin-top: 64px;
}
.output-item h3 { font-size: 20px; font-weight: 600; margin-bottom: 10px; letter-spacing: -0.3px; }
.output-item p { font-size: 15px; color: var(--gray); line-height: 1.7; }
.output-accent { width: 32px; height: 3px; margin-bottom: 20px; border-radius: 2px; background: var(--accent); }

/* FAQ SECTION */
.faq-section {
  padding: 120px 0;
  background: #ffffff;
  border-top: 1px solid rgba(28,27,26,0.06);
}
.faq-container { max-width: 760px; margin: 0 auto; }
.faq-category {
  font-family: var(--font-display); font-size: 13px;
  color: var(--accent); text-transform: uppercase;
  letter-spacing: 2px; margin: 60px 0 24px 0; font-weight: 600;
}
.faq-category:first-of-type { margin-top: 0; }
.faq-item { border-bottom: 1px solid rgba(28,27,26,0.08); }
.faq-item details { width: 100%; }
.faq-item summary {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24px 0; font-size: 18px; font-weight: 500;
  letter-spacing: -0.3px; color: var(--text); cursor: pointer; list-style: none;
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+'; font-size: 28px; font-weight: 300;
  color: var(--gray); transition: transform 0.3s ease;
}
.faq-item details[open] summary::after { transform: rotate(45deg); }
.faq-item .faq-answer { padding-bottom: 32px; font-size: 16px; color: var(--gray); line-height: 1.6; }

/* CTA SECTION */
.cta-section {
  padding: 160px 0; text-align: center; position: relative;
  background: var(--cream);
}
.cta-section::before {
  content: ''; position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(61,90,252,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.cta-section h2 {
  font-size: clamp(36px, 5vw, 60px); font-weight: 700;
  letter-spacing: -1.5px; margin-bottom: 20px; line-height: 1.1;
}
.cta-section p { font-size: 18px; color: var(--gray); margin-bottom: 40px; font-weight: 300; }

/* FOOTER */
footer { background: #1c1b1a; color: #f5f2eb; padding: 60px 0 40px; }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 60px; }
.footer-brand p { color: #8a8780; font-size: 14px; margin-top: 12px; max-width: 280px; line-height: 1.6; }
.footer-col h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px; color: #8a8780; margin-bottom: 16px; font-family: var(--font-display); }
.footer-col a { display: block; font-size: 14px; color: #c4c1b8; padding: 4px 0; transition: color 0.2s; }
.footer-col a:hover { color: #f5f2eb; }
.footer-bottom { border-top: 1px solid rgba(245,242,235,0.08); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; color: #8a8780; font-size: 13px; }

/* RESPONSIVE */
@media (max-width: 768px) {
  section { padding: 80px 0; }
  .hero { min-height: auto; padding-top: 120px; padding-bottom: 60px; }
  .hero h1 { font-size: 40px; letter-spacing: -1px; }
  .nav-links { display: none; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .hero-meta { gap: 20px; }
  .timeline-item { gap: 16px; }
}

/* ANIMATIONS */
.fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.fade-up.visible { opacity: 1; transform: translateY(0); }
</style>
</head>
