<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Technical Hackathons — Habitat</title>
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="description" content="Full-day technical builds for developers and founders. Team-based, expertly-judged. Build something that matters.">
<link rel="preconnect" href="https://fonts.googleapis.com">
