<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Habitat — The fastest path from zero to real</title>
<meta name="description" content="From idea to live product. Habitat evenings, technical hackathons, and founder residencies across Belgium.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================
   CSS VARIABLES — Change these to restyle everything
   ============================================ */
:root {
  --bg: #fafaf8;           /* page background (warm white) */
  --text: #1c1b1a;         /* main text (near-black) */
  --cream: #f0ede6;        /* alt section background */
  --gray: #6b6864;         /* secondary text */
  --gray-light: #8a8780;   /* muted / subtext */
  --accent: #3d5afc;       /* Habitat blue */
  --accent-glow: #2d4ae8;  /* darker hover for light mode */
  --coral: #e85a35;
  --teal: #16b889;
  --purple: #7c4fcc;
  --font-display: 'Space Mono', monospace;
  --font-body: 'Outfit', sans-serif;
}

/* ============================================
   RESET & BASE
   ============================================ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }

/* ============================================
   LAYOUT
   ============================================ */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

section {
  padding: 120px 0;
}

/* ============================================
   NAVIGATION
   ============================================ */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 20px 0;
  background: rgba(250,250,248,0.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(28,27,26,0.08);
}

nav .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

.logo span { color: var(--accent); }

.nav-links {
  display: flex;
  gap: 32px;
  align-items: center;
  list-style: none;
}

.nav-links a {
  font-size: 14px;
  font-weight: 400;
  color: var(--gray);
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--text); }

.nav-cta {
  background: var(--accent);
  color: #ffffff !important;
  padding: 10px 24px;
  border-radius: 6px;
  font-weight: 600;
  font-size: 14px;
  transition: background 0.2s;
}

.nav-cta:hover { background: var(--accent-glow) !important; }

/* ============================================
   HERO
   ============================================ */
.hero {
  min-height: 85vh;
  display: flex;
  align-items: center;
  padding-top: 100px;
  position: relative;
}

.hero::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(61,90,252,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  max-width: 800px;
}

.hero-label {
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.hero-label::before {
  content: '';
  width: 40px;
  height: 1px;
  background: var(--accent);
}

.hero h1 {
  font-family: var(--font-body);
  font-size: clamp(48px, 7vw, 80px);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -2px;
  margin-bottom: 28px;
}

.hero h1 em {
  font-style: normal;
  color: var(--accent);
}

.hero-sub {
  font-size: 20px;
  color: var(--gray);
  max-width: 560px;
  line-height: 1.6;
  margin-bottom: 48px;
  font-weight: 300;
}

.hero-buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--accent);
  color: #ffffff;
  padding: 16px 32px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 16px;
  transition: all 0.2s;
  border: none;
  cursor: pointer;
}

.btn-primary:hover {
  background: var(--accent-glow);
  transform: translateY(-1px);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  color: var(--text);
  padding: 16px 32px;
  border-radius: 8px;
  font-weight: 500;
  font-size: 16px;
  border: 1px solid rgba(28,27,26,0.18);
  transition: all 0.2s;
  cursor: pointer;
}

.btn-secondary:hover {
  border-color: rgba(28,27,26,0.35);
  background: rgba(28,27,26,0.04);
}

/* ============================================
   STATS TICKER
   ============================================ */
.stats-bar {
  border-top: 1px solid rgba(28,27,26,0.08);
  border-bottom: 1px solid rgba(28,27,26,0.08);
  padding: 40px 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 32px;
  text-align: center;
}

.stat-num {
  font-family: var(--font-display);
  font-size: 36px;
  font-weight: 700;
  color: var(--text);
  line-height: 1;
}

.stat-label {
  font-size: 13px;
  color: var(--gray);
  margin-top: 6px;
  font-weight: 400;
}

/* ============================================
   PHOTO STRIP (scrolling event photos)
   ============================================ */
.photo-strip {
  padding: 80px 0;
  overflow: hidden;
  background: var(--cream);
}

.photo-row {
  display: flex;
  gap: 16px;
  animation: scroll-photos 30s linear infinite;
}

.photo-row img, .photo-row .photo-placeholder {
  width: 340px;
  height: 220px;
  object-fit: cover;
  border-radius: 12px;
  flex-shrink: 0;
}

/* === IMAGE PLACEHOLDERS ===
   These boxes show where YOUR photos go.
   Replace <div class="photo-placeholder"> with <img src="images/your-photo.jpg">
*/
.photo-placeholder {
  background: rgba(28,27,26,0.07);
  border: 1px dashed rgba(28,27,26,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gray);
  font-size: 13px;
  font-family: var(--font-display);
}

@keyframes scroll-photos {
  0% { transform: translateX(0); }
  100% { transform: translateX(calc(-356px * 7)); }
}

/* ============================================
   THREE PRODUCTS
   ============================================ */
.products { padding: 120px 0; }

.section-label {
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.section-title {
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 700;
  letter-spacing: -1.5px;
  margin-bottom: 16px;
  line-height: 1.1;
}

.section-sub {
  font-size: 18px;
  color: var(--gray);
  max-width: 600px;
  margin-bottom: 64px;
  font-weight: 300;
}

.product-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
}

.product-card {
  background: #ffffff;
  border: 1px solid rgba(28,27,26,0.08);
  border-radius: 16px;
  padding: 40px 32px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(28,27,26,0.04);
}

.product-card:hover {
  border-color: rgba(28,27,26,0.16);
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(28,27,26,0.08);
}

.product-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
}

.product-card.evenings::before { background: var(--teal); }
.product-card.hackathons::before { background: var(--accent); }
.product-card.residency::before { background: var(--purple); }

.product-tag {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 4px;
  margin-bottom: 24px;
}

.evenings .product-tag { background: rgba(22,184,137,0.1); color: var(--teal); }
.hackathons .product-tag { background: rgba(61,90,252,0.1); color: var(--accent); }
.residency .product-tag { background: rgba(124,79,204,0.1); color: var(--purple); }

.product-card h3 {
  font-size: 24px;
  font-weight: 600;
  margin-bottom: 12px;
  letter-spacing: -0.5px;
}

.product-card p {
  color: var(--gray);
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 24px;
}

.product-details {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.product-details li {
  font-size: 13px;
  color: var(--gray);
  background: rgba(28,27,26,0.04);
  padding: 6px 14px;
  border-radius: 20px;
  border: 1px solid rgba(28,27,26,0.07);
}

/* ============================================
   FUNNEL SECTION
   ============================================ */
.funnel {
  background: var(--cream);
  border-top: 1px solid rgba(28,27,26,0.06);
  border-bottom: 1px solid rgba(28,27,26,0.06);
}

.funnel-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  padding: 40px 0;
}

.funnel-step {
  text-align: center;
  flex: 1;
  min-width: 160px;
}

.funnel-num {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 4px;
}

.funnel-label {
  font-size: 14px;
  color: var(--gray);
}

.funnel-arrow {
  color: var(--gray-light);
  font-size: 24px;
  opacity: 0.5;
}

/* ============================================
   LOGOS
   ============================================ */
.logos-section {
  padding: 80px 0;
  text-align: center;
}

.logos-label {
  font-size: 13px;
  color: var(--gray);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 40px;
  font-family: var(--font-display);
}

.logos-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48px;
  flex-wrap: wrap;
  opacity: 0.5;
  max-width: 900px;
  margin: 0 auto;
}

/* === LOGO TEXT ===
   Clean typography replacing image logos
*/
.logo-text {
  color: var(--gray);
  font-family: var(--font-body);
  font-size: 22px;
  font-weight: 500;
  letter-spacing: -0.5px;
}

/* ============================================
   TESTIMONIALS
   ============================================ */
.testimonials {
  padding: 120px 0;
  background: var(--cream);
}

.testimonial-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 24px;
  margin-top: 64px;
}

.testimonial-card {
  background: #ffffff;
  border: 1px solid rgba(28,27,26,0.08);
  border-radius: 16px;
  padding: 36px;
  box-shadow: 0 1px 4px rgba(28,27,26,0.04);
}

.testimonial-text {
  font-size: 17px;
  line-height: 1.7;
  margin-bottom: 24px;
  color: var(--text);
  font-weight: 300;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* === TESTIMONIAL PHOTO PLACEHOLDER ===
   Replace with: <img src="images/people/leon.jpg" alt="Leon" class="testimonial-avatar">
*/
.testimonial-avatar, .avatar-placeholder {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  background: rgba(28,27,26,0.07);
  border: 1px dashed rgba(28,27,26,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: var(--gray);
}

.testimonial-name {
  font-weight: 600;
  font-size: 15px;
}

.testimonial-role {
  font-size: 13px;
  color: var(--gray);
}

/* ============================================
   WHY SECTION
   ============================================ */
.why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 48px;
  margin-top: 64px;
}

.why-item h3 {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 10px;
  letter-spacing: -0.3px;
}

.why-item p {
  font-size: 15px;
  color: var(--gray);
  line-height: 1.7;
}

.why-item-accent {
  width: 32px;
  height: 3px;
  margin-bottom: 20px;
  border-radius: 2px;
}

/* ============================================
   CTA SECTION
   ============================================ */
.cta-section {
  padding: 160px 0;
  text-align: center;
  position: relative;
  background: var(--cream);
}

.cta-section::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(61,90,252,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.cta-section h2 {
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  letter-spacing: -1.5px;
  margin-bottom: 20px;
  line-height: 1.1;
}

.cta-section p {
  font-size: 18px;
  color: var(--gray);
  margin-bottom: 40px;
  font-weight: 300;
}

/* ============================================
   FOOTER — stays dark for visual anchor
   ============================================ */
footer {
  background: #1c1b1a;
  color: #f5f2eb;
  padding: 60px 0 40px;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 60px;
}

.footer-brand p {
  color: #8a8780;
  font-size: 14px;
  margin-top: 12px;
  max-width: 280px;
  line-height: 1.6;
}

.footer-col h4 {
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #8a8780;
  margin-bottom: 16px;
  font-family: var(--font-display);
}

.footer-col a {
  display: block;
  font-size: 14px;
  color: #c4c1b8;
  padding: 4px 0;
  transition: color 0.2s;
}

.footer-col a:hover { color: #f5f2eb; }

.footer-bottom {
  border-top: 1px solid rgba(245,242,235,0.08);
  padding-top: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #8a8780;
  font-size: 13px;
}

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 768px) {
  section { padding: 80px 0; }
  .hero { min-height: auto; padding-top: 120px; padding-bottom: 60px; }
  .hero h1 { font-size: 40px; letter-spacing: -1px; }
  .stats-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .nav-links { display: none; }
  .funnel-arrow { display: none; }
  .funnel-visual { gap: 16px; }
  .testimonial-grid { grid-template-columns: 1fr; }
  .product-cards { grid-template-columns: 1fr; }
}

/* ============================================
   ANIMATIONS (on scroll)
   ============================================ */
.fade-up {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
</head>
