export type TaskInputType = "text" | "textarea" | "url" | "confirmation" | "ai-generated";

export type GeneratorType =
  | "mvp-scope"
  | "lovable-prompt"
  | "target-customer"
  | "outreach-messages"
  | "customer-segments"
  | "single-segment"
  | "linkedin-search"
  | "segment-outreach"
  | "automation-analysis";

export interface AIConfig {
  generatorType: GeneratorType;
  requiredPhase1Tasks: string[];
  showCopyButton?: boolean;
}

export interface SprintTask {
  key: string;
  title: string;
  description?: string;
  exampleText?: string;
  warningText?: string;
  helperText?: string;
  toolLink?: { label: string; url: string };
  inputType: TaskInputType;
  placeholder?: string;
  required?: boolean;
  optional?: boolean;
  aiConfig?: AIConfig;
  recommended?: boolean;
  subNote?: string;
  checklist?: string[];
}

export interface PhaseData {
  phase: string;
  label: string;
  description: string;
