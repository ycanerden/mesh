import { useState, useRef } from 'react';
import { supabase } from '@/integrations/supabase/client';
import { toast } from 'sonner';
import type { GeneratorType } from '@/data/sprintTasks';

const AI_COOLDOWN_MS = 10_000;

export interface Phase1Data {
  problem: string;
  solution: string;
  customer: string;
  name: string;
  mvpScope?: string;
  targetCustomer?: string;
  unfairAdvantage?: string;
  problemValidation?: string;
  successMetrics?: string;
  workflow?: string;
  painPoints?: string;
  toolsUsed?: string;
  timeSpent?: string;
  aiAnalysis?: string;
}

export interface SegmentData {
  id?: string;
  name: string;
  companyType: string;
  jobTitles: string[];
  whyTheyCare: string;
  isCustom?: boolean;
}

export interface SearchFilters {
  location?: string;
  connectionLevel?: '1st' | '2nd' | '3rd+' | 'all';
  companySize?: string;
}

export function useAIGeneration() {
  const [isGenerating, setIsGenerating] = useState(false);
  const lastGenerationTime = useRef<number>(0);

  const generate = async (
    type: GeneratorType,
    phase1Data: Phase1Data,
    segmentData?: SegmentData,
    searchFilters?: SearchFilters,
    track?: string
  ): Promise<string | null> => {
    const now = Date.now();
    const elapsed = now - lastGenerationTime.current;
    if (elapsed < AI_COOLDOWN_MS) {
      const waitSec = Math.ceil((AI_COOLDOWN_MS - elapsed) / 1000);
      toast.error(`Please wait ${waitSec}s before generating again`);
      return null;
    }

    setIsGenerating(true);
    lastGenerationTime.current = now;

    try {
      const { data, error } = await supabase.functions.invoke('generate-startup-content', {
        body: { type, phase1Data, segmentData, searchFilters, track: track || 'startup' },
      });

      if (error) {
        console.error('AI generation error:', error);
        toast.error('Failed to generate content. Please try again.');
        return null;
      }

      if (data?.error) {
        toast.error(data.error);
        return null;
      }

      return data?.content || null;
    } catch (err) {
      console.error('AI generation error:', err);
      toast.error('Failed to generate content. Please try again.');
      return null;
    } finally {
      setIsGenerating(false);
    }
  };

  return { generate, isGenerating };
}
