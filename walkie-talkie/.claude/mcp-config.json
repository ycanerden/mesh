{
  "mcpServers": {
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_API_KEY_HERE"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": ["-y", "@smithery/mcp-remote", "http://localhost:22360/mcp"]
    }
  }
}
